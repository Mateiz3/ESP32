#include "painlessMesh.h"

#define MESH_PREFIX     "ESP_mesh"
#define MESH_PASSWORD   "password123"
#define MESH_PORT       5555

//  Change this for each node (1, 2, 3, etc )
#define STATIC_NODE_ID  3

Scheduler userScheduler;
painlessMesh mesh;

void receivedCallback(uint32_t from, String &msg);
void sendMessage();
void updateClosestNode();

Task taskSendMessage(TASK_SECOND * 5, TASK_FOREVER, &sendMessage);
Task taskUpdateClosest(TASK_SECOND * 10, TASK_FOREVER, &updateClosestNode);

uint32_t closestNode = 0;
uint32_t closestRTT = UINT32_MAX;
std::map<uint32_t, uint32_t> nodeRTTs;  // Stores RTT values for each node

void sendMessage() {
    uint32_t timestamp = millis();
    String msg = String(STATIC_NODE_ID) + ":" + String(timestamp);
    
    Serial.printf("\n📨 Node %u sending message.\n", STATIC_NODE_ID);
    mesh.sendBroadcast(msg);
    
    // Randomize send interval slightly to avoid collisions
    taskSendMessage.setInterval(random(TASK_SECOND * 3, TASK_SECOND * 7));
}

void receivedCallback(uint32_t from, String &msg) {
    int separatorIndex = msg.indexOf(':');
    if (separatorIndex == -1) return;  // Ignore invalid messages

    uint32_t senderID = msg.substring(0, separatorIndex).toInt();
    uint32_t sentTime = msg.substring(separatorIndex + 1).toInt();
    uint32_t rtt = millis() - sentTime;

    if (sentTime > millis()) return;  // Ignore future timestamps (overflow)

    nodeRTTs[senderID] = rtt;  // Store RTT value

    Serial.printf("📩 Node %u received from %u (RTT: %u ms)\n", STATIC_NODE_ID, senderID, rtt);

    //  Send acknowledgment back
    String ackMsg = String(STATIC_NODE_ID) + ":" + String(millis());
    mesh.sendSingle(from, ackMsg);
}

void updateClosestNode() {
    uint32_t newClosestNode = 0;
    uint32_t newClosestRTT = UINT32_MAX;

    if (nodeRTTs.empty()) {
        Serial.println("⚠️ No active closest node detected.");
        return;
    }

    for (const auto& node : nodeRTTs) {
        yield();  //  Prevent watchdog reset
        if (node.second < newClosestRTT) {
            newClosestNode = node.first;
            newClosestRTT = node.second;
        }
    }

    if (newClosestNode != closestNode) {  //  Print only when closest node changes
        Serial.printf("🔍 Closest node to %u is Node %u (RTT: %u ms)\n", STATIC_NODE_ID, newClosestNode, newClosestRTT);
        closestNode = newClosestNode;
        closestRTT = newClosestRTT;
    }

    //  Clear RTT list every cycle
    nodeRTTs.clear();
}

void newConnectionCallback(uint32_t nodeId) {
    Serial.printf("🔗 New node connected: %u\n", nodeId);
}

void changedConnectionCallback() {
    Serial.println("🔄 Mesh network connections changed.");
}

void setup() {
    Serial.begin(115200);
    Serial.println(" Starting ESP8266 Mesh...");

    mesh.setDebugMsgTypes(ERROR | STARTUP);
    mesh.init(MESH_PREFIX, MESH_PASSWORD, &userScheduler, MESH_PORT);
    
    mesh.onReceive(&receivedCallback);
    mesh.onNewConnection(&newConnectionCallback);
    mesh.onChangedConnections(&changedConnectionCallback);

    userScheduler.addTask(taskSendMessage);
    userScheduler.addTask(taskUpdateClosest);
    taskSendMessage.enable();
    taskUpdateClosest.enable();

    Serial.println("✅ Mesh network initialized.");
}

void loop() {
    mesh.update();
}
